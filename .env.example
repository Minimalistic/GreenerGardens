# GardenVault Configuration

# Server
PORT=3000

# Database (path relative to project root, or absolute)
DATABASE_PATH=./data/gardenvault.db

# Weather API (Phase 2)
# OPENWEATHER_API_KEY=

# LLM Assistant (Phase 3)
# ANTHROPIC_API_KEY=

# Push Notifications (Phase 6)
# Generate keys with: npx tsx packages/backend/src/scripts/generate-vapid-keys.ts
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:your-email@example.com
