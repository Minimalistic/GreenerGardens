{
  "name": "gardenvault",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=@gardenvault/backend",
    "dev:frontend": "npm run dev --workspace=@gardenvault/frontend",
    "build": "npm run build --workspaces",
    "typecheck": "tsc --build packages/shared packages/backend packages/frontend"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "postcss": ">=8.5.10"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.0"
  }
}
